# ============================================================
# Nucleus Remote Access Portal — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# --- Shared / Environment ---
ENVIRONMENT=development
# Options: development | staging | production

# --- PostgreSQL ---
DATABASE_URL=postgresql://nucleus:nucleus_dev@localhost:5432/nucleus_portal
POSTGRES_USER=nucleus
POSTGRES_PASSWORD=nucleus_dev
POSTGRES_DB=nucleus_portal
POSTGRES_PORT=5432

# --- Redis ---
REDIS_URL=redis://localhost:6379/0
REDIS_PORT=6379

# --- API Server ---
SERVER_PORT=8080
JWT_SECRET=change-me-to-a-strong-random-secret-min-32-chars
JWT_EXPIRY_HOURS=24
AGENT_WS_SECRET=change-me-agent-ws-shared-secret
API_CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Nucleus Remote Access Portal
NEXT_PUBLIC_VERSION=1.0.0

# --- Cloudflare (optional for local dev, required for production) ---
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_TOKEN=
CLOUDFLARE_TUNNEL_ID=
# For Cloudflare Access (Zero Trust)
CF_ACCESS_TEAM_DOMAIN=
CF_ACCESS_AUD=

# --- Session Defaults ---
SESSION_DEFAULT_TTL_SECONDS=3600
SESSION_MAX_TTL_SECONDS=28800
SESSION_IDLE_TIMEOUT_SECONDS=1800
SESSION_LOCAL_PORT_RANGE_START=14000
SESSION_LOCAL_PORT_RANGE_END=14999

# --- Agent ---
AGENT_DEVICE_ID=N-LOCAL-DEV
AGENT_CONTROL_PLANE_URL=ws://localhost:8080/ws/agent
AGENT_TENANT_ID=tenant-alpha
AGENT_INVENTORY_SCAN_INTERVAL=60
AGENT_HEARTBEAT_INTERVAL=30
AGENT_MAX_CONCURRENT_SESSIONS=5

# --- Windows Helper ---
NUCLEUS_API_URL=http://localhost:8080
NUCLEUS_TOKEN_PATH=~/.nucleus/config.json

# --- Logging ---
LOG_LEVEL=debug
# Options: debug | info | warn | error
